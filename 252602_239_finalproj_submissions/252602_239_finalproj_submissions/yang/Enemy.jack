class Enemy {
    field int x; // x position
    field int y; // y position
    field int width; // hit width
    field int height; // hit height
    field int targetY; // stop height
    field int shootTimer; // shoot cooldown
    field int hp; // enemy hp
    field int moveTimer; // turn timer
    field int moveDir; // move direction
    field int moveDelay; // boss speed
    field int moveSeed; // movement seed
    field int moveToggle; // smooth toggle
    field int bossLevel; // boss number
    field boolean active; // alive flag
    field boolean boss; // boss flag

    constructor Enemy new(int startX, int startY) {
        // sets the start position(top left) and the enemy size.
        let x = startX;
        let y = startY;
        let width = 21; // calculated from the new draw image
        let height = 12; // calculated from the new draw image
        let targetY = 80; // the height that enemy stop moving downward
        let shootTimer = 0; // time until the next bullet
        let hp = 1;
        let moveTimer = 1;
        let moveDir = 0;
        let moveDelay = 0;
        let moveSeed = 7;
        let moveToggle = 0;
        let bossLevel = 0;
        let active = false; // alive or dead
        let boss = false;

        return this;
    }

    method void reset(int startX, int startY) {
        // reset normal enemy
        // reuses old enemy object with a new position to save memory.
        let x = startX;
        let y = startY;
        let width = 21;
        let height = 12;
        let targetY = 80;
        let shootTimer = 0;
        let hp = 1;
        let moveTimer = 1;
        let moveDir = 0;
        let moveDelay = 0;
        let moveSeed = startX + 7;
        let moveToggle = 0;
        let bossLevel = 0;
        let active = true;
        let boss = false;
        return;
    }

    method void resetBoss(int startX, int startY, int bossHp, int level) {
        // reset boss enemy
        // reuses old enemy object as a boss enemy.
        let x = startX;
        let y = startY;
        let width = 96;
        let height = 58;
        let targetY = 30;
        let shootTimer = 15;
        let hp = bossHp;
        let moveTimer = 0;
        let moveDir = 0;
        let moveDelay = 0;
        let moveSeed = startX + Math.multiply(level + 1, 19);
        let moveToggle = 0;
        let bossLevel = level;
        let active = true;
        let boss = true;
        return;
    }

    method void update() {
        // update enemy
        if (boss) {
            do updateBoss();
            return;
        }

        // let the enemy move down until it reaches the shooting height.
        if (y < targetY) {
            let y = y + 1;
            let moveTimer = moveTimer - 1;
            if (moveTimer = 0) {
                if (y < targetY) {
                    let y = y + 1;
                }
                let moveTimer = 2;
            }
        }

        // counts down to the next shot after reaching the fixed height.
        if ((y = targetY) & (shootTimer > 0)) {
            let shootTimer = shootTimer - 1;
        }
        return;
    }

    method void updateBoss() {
        // update boss
        if (y < targetY) {
            let y = y + 1;
        }
        else {
            if (moveTimer = 0) {
                do chooseBossDirection();
                let moveTimer = 12;
            }

            if (moveDelay > 0) {
                let moveDelay = moveDelay - 1;
            }
            else {
                if (moveDir = 0) {
                    if (y > 8) {
                        let y = y - 1;
                    }
                }
                if (moveDir = 1) {
                    if (y < 100) {
                        let y = y + 1;
                    }
                }
                if (moveDir = 2) {
                    if (x > 16) {
                        let x = x - 4;
                    }
                }
                if (moveDir = 3) {
                    if (x < 408) {
                        let x = x + 4;
                    }
                }
                if ((moveDir = 2) | (moveDir = 3)) {
                    let moveDelay = getBossHorizontalDelay();
                }
                else {
                    let moveDelay = getBossMoveDelay();
                }
            }

            let moveTimer = moveTimer - 1;
        }

        if ((y > 0) & (shootTimer > 0)) {
            let shootTimer = shootTimer - 1;
        }
        return;
    }

    method void chooseBossDirection() {
        // random boss path
        if (bossLevel = 0) {
            let moveSeed = moveSeed + x + y + shootTimer + 11;
        }
        if (bossLevel = 1) {
            let moveSeed = moveSeed + Math.multiply(x, 2) + y + shootTimer + 23;
        }
        if (bossLevel > 1) {
            let moveSeed = moveSeed + x + Math.multiply(y, 2) + shootTimer + Math.multiply(bossLevel, 13);
        }
        while (moveSeed > 39) {
            let moveSeed = moveSeed - 40;
        }
        let moveDir = Math.divide(moveSeed, 10);
        return;
    }

    method int getBossMoveDelay() {
        // boss speed delay
        var int delay;

        let delay = 3 - Math.divide(bossLevel, 2);
        if (bossLevel = 1) {
            let delay = 2;
        }
        if (delay < 1) {
            return 1;
        }
        return delay;
    }

    method int getBossHorizontalDelay() {
        // smooth x delay
        var int delay;

        let delay = getBossMoveDelay();
        if (delay = 3) {
            return 1;
        }
        if (delay = 2) {
            if (moveToggle = 0) {
                let moveToggle = 1;
                return 1;
            }
            let moveToggle = 0;
            return 0;
        }
        return 0;
    }

    method void deactivate() {
        // deactivate enemy
        // enemy is dead after being hit.
        let active = false;
        return;
    }

    method boolean isActive() {
        return active;
    }

    method boolean canShoot() {
        // ready to shoot
        // whether the enemy is ready to fire.
        if (~boss) {
            if (~(y = targetY)) {
                return false;
            }
        }
        if ((y > 0) & (shootTimer = 0)) {
            return true;
        }
        return false;
    }

    method void resetShootTimer(int smallInterval) {
        // reset cooldown
        let shootTimer = smallInterval;
        return;
    }

    method boolean takeHit() {
        // lose hp
        let hp = hp - 1;
        if (hp < 1) {
            let active = false;
            return true;
        }
        return false;
    }

    method boolean isBoss() {
        return boss;
    }

    method int getHp() {
        return hp;
    }

    method void draw() {
        // draw enemy
        var int location;
        var int memAddress;

        // sets the enemy position into a screen memory location.
        let location = Math.multiply(y, 32) + Math.divide(x, 16);

        if (boss) {
            do drawBoss(location);
            return;
        }

        let memAddress = 16384 + location;

        // draws the enemy bitmap row by row in screen memory.
        do Memory.poke(memAddress, 3584);
        do Memory.poke(memAddress + 32, 32704);
        do Memory.poke(memAddress + 64, -1);
        do Memory.poke(memAddress + 96, -16);
        do Memory.poke(memAddress + 128, 25792);
        do Memory.poke(memAddress + 160, 25792);
        do Memory.poke(memAddress + 192, 17472);
        do Memory.poke(memAddress + 224, 17472);
        do Memory.poke(memAddress + 256, 17472);
        do Memory.poke(memAddress + 288, 1024);
        do Memory.poke(memAddress + 320, 1024);
        do Memory.poke(memAddress + 352, 1024);

        // draws the extra right-side bits in the rows that use the next word.
        do Memory.poke(memAddress + 65, 31);
        do Memory.poke(memAddress + 97, 1);
        return;
    }

    method void drawBoss(int location) {
        // draw boss bitmap
        var int memAddress;
        let memAddress = 16384 + location;

