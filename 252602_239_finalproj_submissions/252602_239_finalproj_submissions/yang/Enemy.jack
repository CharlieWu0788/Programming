    method int getX() {
        return x;
    }

    method int getY() {
        return y;
    }

    method int getWidth() {
        return width;
    }

    method int getHeight() {
        return height;
    }

    method int getBulletX() {
        // gives the bullet start x at the center of the new enemy image
        return x + 9;
    }

    method int getBulletY() {
        // gives the bullet start y just under the new enemy image.
        return y + height;
    }

}
