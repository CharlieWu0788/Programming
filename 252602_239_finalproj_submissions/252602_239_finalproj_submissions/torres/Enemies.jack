    method void eraseEnemy() {
        var int x, y;

        //prevents the program from crashing when it tries to erase an enemy that could be considered off screen
        if (gridX < 0) {
            return;
        }
        let x = 2 + (gridX * 16);
        let y = 2 + (gridY * 48);
        do Screen.setColor(false);
        do Screen.drawRectangle(x, y, x + 15, y + 47);
        return;
    }

    //moves the enemy across the screen
    method void move(int time) {
        do eraseEnemy();
        let counter = counter + time;
        if (enemyID = 1) {             //basic enemy
            if (counter > 999) {
                let counter = 0;
                let gridX = gridX - 1;
            }
        }
        if (enemyID = 2) {             //the wall moves at a 5th of the basic enemy's speed
            if (counter > 4999) {
                let counter = 0;
                let gridX = gridX - 1;
            }
        }
        if (enemyID = 3) {
            if (counter > 329) {       //the blob moves quickly, so counter threshold should be lower than basic enemy
                let counter = 0;
                let gridX = gridX - 1;
            }
        }
        if (enemyID = 4) {
            if (counter > 1224) {       //the thinker, moves slower than the basic enemy, faster than the wall, but moves diagonally
                let counter = 0;
                let gridX = gridX - 1;
                let gridY = gridY - direction;
                if (gridY < 0) {        //stick to top and reverse
                    let gridY = 0;
                    let direction = -direction;
                }
                if (gridY > 3) {        //stick to bottom and reverse
                    let gridY = 3;
                    let direction = -direction;
                }
            }
        }
        if (gridX < 0) {       //detects if the left edge of the grid has been reached
                do Output.moveCursor(20, 0);
                do Output.printString(gameOver);
                do Sys.halt();
                return;
        }
        do draw();
        return;
    }
}