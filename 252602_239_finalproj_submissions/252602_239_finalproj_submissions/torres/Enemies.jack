class Enemies {
    field int gridX, gridY; //location of the enemy, where gridX can range from 0-23, and y from 0-3
                            //gridX will move ahead 16 bits instead of 48 in order to make movement more gradual
    field int health;       //the health of the enemy
    field int enemyID;      /*a numerical value for the enemy to determine which type of enemy we want
                            * 0 = null
                            * 1 = basic enemy
                            * 2 = the wall, skipped leg day, so walks slow, but has a lot of health
                            * 3 = the blob, rushes towards the front, but fragile
                            * 4 = the thinker, unable to think straight, let alone walk straight (moves diagonally forward every movement oppurtunity)*/
    field int counter;      //a counter to count how many times Sys.wait() has been used in TDGame
    field String gameOver;
    field int direction;    //used to determine which direction the thinker will jump. 1 = up, -1 = down

    constructor Enemies new(int Ax, int Ay, int Ahealth, int ID) {
        let gridX = Ax;
        let gridY = Ay;
        let health = Ahealth;
        let enemyID = ID;
        let counter = 0;
        let gameOver = "       You got overwhelmed. Game over D:        ";
        let direction = 1;
        return this;
    }

    method void dispose() {
        do gameOver.dispose();
        do Memory.deAlloc(this);
        return;
    }

    //returns the current row the enemy is on to help PlayerObjects detect an enemy
    method int getRow() {
        return gridY;
    }

    method void setRow(int row) {
        let gridY = row;
        return;
    }

    method int getGridX() {
        return gridX;
    }

    method void takeDamage(int amount) {
        let health = health - amount;
        return;
    }

    method int getHealth() {
        return health;
    }

