/* The PlayerObjects class holds all the possible "towers" a user can place, conviently held in one
 * class as they share the same code, and there is no inheritance in jack (initially).
*/

class PlayerObjects {
    field int gridX, gridY;  //takes in the position of the Cursor on the grid to determine where to place
    field int nameID; //ID name of the type of player object we want to place, represented by numbers
                      //1 = "teto"; 2 = "Mari"; 3 = "Dr. P"; 4 = "inkling"
    field int currency; /*  will be used to keep track of how much each object costs (or adds)
                        *   teto's cost = 4
                        *   Mari's cost = 3
                        *   Dr. P's cost = 10
                        *   inkling's cost = 10  */
    field int counter;       //general purpose counter (timer)
    field int attackCounter; //used to determine how much time has passed until next attack can be launched

    constructor PlayerObjects new(int Ax, int Ay) {
        let gridX = Ax;
        let gridY = Ay;
        let nameID = 0;
        let currency = 0;
        let counter = 0;
        return this;
    }

    method void dispose() {
        do Memory.deAlloc(this);
        return;
    }

    method void setName(int Aname) {
        let nameID = Aname;
        return;
    }

    method int getNameID() {
        return nameID;
    }

    method int getRow() {
        return gridY;
    }

    method int getGridX() {
        return gridX;
    }

    //advances the attack timer to determine when towers can shoot
    method void attack(int time) {
        let attackCounter = attackCounter + time;
        return;
    }

    //returns damage if the attack is ready and resets the counter
    method int fire() {
        if ((attackCounter > 350) & (nameID = 1)) {      //teto's attack
            let attackCounter = 0;
            return 15;
        }
        if ((attackCounter > 1500) & (nameID = 3)) {     //Dr. P's attack
            let attackCounter = 0;
            return 75;
        }
        return 0;
    }

    method void draw() {
