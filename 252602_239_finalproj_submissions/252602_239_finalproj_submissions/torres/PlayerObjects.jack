    method int getCurrency() {
        return currency;
    }

    //increases currency, meaning it is tied to Mari and should only be used with her
    method int updateCurrency(int time){
        let counter = counter + time;
        if (counter > 1100) {
            let counter = 0;
            return 1;
        }
        return 0;
    }
}