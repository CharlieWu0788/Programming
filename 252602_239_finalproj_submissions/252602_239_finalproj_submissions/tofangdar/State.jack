    method void dispose(){
        // gets rid of the all of the strings
        // resets their definitions
        do name.dispose();
        do founded.dispose();
        do population.dispose();
        do capital.dispose();
        do largestCity.dispose();
        do Memory.deAlloc(this);
        return;
    }
}