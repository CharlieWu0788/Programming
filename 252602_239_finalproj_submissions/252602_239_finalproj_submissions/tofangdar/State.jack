class State {
    field int id;
    field String name, founded, population, capital, largestCity;

    constructor State new(int stateId){
        let id = stateId;
        do load();
        return this;
    }

    method void load(){
        // west
        if (id = 1)  { do drawCalifornia(); }
        if (id = 2)  { do drawOregon(); }
        if (id = 3)  { do drawWashington(); }
        if (id = 4)  { do drawNevada(); }
        if (id = 5)  { do drawUtah(); }
        if (id = 6)  { do drawMontana(); }
        if (id = 7)  { do drawWyoming(); }
        if (id = 8)  { do drawColorado(); }
        if (id = 9)  { do drawArizona(); }
        if (id = 10) { do drawNewMexico(); }
        if (id = 11) { do drawIdaho(); }
        if (id = 12) { do drawNorthDakota(); }
        if (id = 13) { do drawSouthDakota(); }
        if (id = 14) { do drawNebraska(); }
        if (id = 15) { do drawKansas(); }
        if (id = 16) { do drawMissouri(); }
        if (id = 17) { do drawIowa(); }
        if (id = 18) { do drawMinnesota(); }
        if (id = 19) { do drawWisconsin(); }
        if (id = 20) { do drawIllinois(); }
        if (id = 21) { do drawIndiana(); }
        if (id = 22) { do drawOhio(); }
        if (id = 23) { do drawMichigan(); }
        if (id = 24) { do drawTexas(); }
        if (id = 25) { do drawOklahoma(); }
        if (id = 26) { do drawLouisiana(); }
        if (id = 27) { do drawMississippi(); }
        if (id = 28) { do drawAlabama(); }
        if (id = 29) { do drawGeorgia(); }
        if (id = 30) { do drawFlorida(); }
        if (id = 31) { do drawArkansas(); }
        if (id = 32) { do drawTennessee(); }
        if (id = 33) { do drawSouthCarolina(); }
        if (id = 34) { do drawNorthCarolina(); }
        if (id = 35) { do drawKentucky(); }
        if (id = 36) { do drawVirginia(); }
        if (id = 37) { do drawWestVirginia(); }
        if (id = 38) { do drawMaryland(); }
        if (id = 39) { do drawDelaware(); }
        if (id = 40) { do drawPennsylvania(); }
        if (id = 41) { do drawNewJersey(); }
        if (id = 42) { do drawNewYork(); }
        if (id = 43) { do drawVermont(); }
        if (id = 44) { do drawNewHampshire(); }
        if (id = 45) { do drawMaine(); }
        if (id = 46) { do drawMassachusetts(); }
        if (id = 47) { do drawConnecticut(); }
        if (id = 48) { do drawRhodeIsland(); }
        do printInfo();
        return;
    }

    method void printInfo(){
        // prints all state info on the right side of the screen
        do Output.moveCursor(2, 33);
        do Output.printString(name);
        do Output.moveCursor(5, 33);
        do Output.printString("Founded: ");
        do Output.printString(founded);
        do Output.moveCursor(7, 33);
        do Output.printString("Pop: ");
        do Output.printString(population);
        do Output.moveCursor(9, 33);
        do Output.printString("Capital: ");
        do Output.printString(capital);
        do Output.moveCursor(11, 33);
        do Output.printString("Largest: ");
        do Output.printString(largestCity);
        do Output.moveCursor(11, 33);
        return;
    }

    method void drawCalifornia(){
        // draw
        do Screen.drawLine(117, 243, 116, 233);
        do Screen.drawLine(116, 233, 109, 219);
