class Region {
    field int id;

    constructor Region new(int regionId){
        let id = regionId;
        do draw();
        return this;
    }

    method void draw(){
        if (id = 1) { do drawWest(); }
        if (id = 2) { do drawMidwest(); }
        if (id = 3) { do drawSouth(); }
        if (id = 4) { do drawNortheast(); }
        return;
    }

    method void drawWest(){
        // outline of west
        do Screen.drawLine(42, 17, 46, 33);
