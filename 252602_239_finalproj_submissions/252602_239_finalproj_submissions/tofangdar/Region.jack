        do Output.printString("ME (6)");
        // Massachusetts
        do Output.moveCursor(11, 22);
        do Output.printString("MA (7)");
        // Connecticut
        do Output.moveCursor(13, 21);
        do Output.printString("CT (8)");
        // Rhode Island
        do Output.moveCursor(13, 28);
        do Output.printString("RI (9)");

        return;
    }

    method void dispose(){
        do Memory.deAlloc(this);
        return;
    }
}