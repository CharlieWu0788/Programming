        do Screen.drawLine(170, 241, 189, 243);
        do Screen.drawLine(189, 243, 191, 236);
        do Screen.drawLine(191, 236, 245, 238);
        do Screen.drawLine(245, 238, 250, 182);
        do Screen.drawLine(250, 182, 260, 182);
        do Screen.drawLine(260, 182, 265, 128);
        do Screen.drawLine(265, 128, 250, 126);
        do Screen.drawLine(250, 126, 263, 12);
        do Screen.drawLine(263, 12, 60, 3);
        do Screen.drawLine(60, 3, 61, 14);
        do Screen.drawLine(61, 14, 54, 24);
        do Screen.drawLine(54, 24, 55, 13);
        do Screen.drawLine(55, 13, 35, 12);
        do Screen.drawLine(35, 12, 41, 18);
        // California Border
        do Screen.drawLine(102, 232, 107, 208);
        do Screen.drawLine(107, 208, 73, 146);
        do Screen.drawLine(73, 146, 77, 97);
        do Screen.drawLine(77, 97, 38, 95);
        // Oregon Border
        do Screen.drawLine(45, 45, 62, 46);
        do Screen.drawLine(62, 46, 61, 56);
        do Screen.drawLine(61, 56, 113, 54);
        do Screen.drawLine(113, 54, 109, 66);
        do Screen.drawLine(109, 66, 113, 67);
        do Screen.drawLine(113, 67, 106, 95);
        do Screen.drawLine(106, 95, 77, 95);
        // Washington Border
        do Screen.drawLine(112, 53, 121, 6);
        // Nevada Border
        do Screen.drawLine(102, 198, 106, 185);
        do Screen.drawLine(106, 185, 115, 188);
        do Screen.drawLine(115, 188, 134, 97);
        do Screen.drawLine(134, 97, 108, 95);
        // Utah Border
        do Screen.drawLine(135, 96, 160, 99);
        do Screen.drawLine(160, 99, 157, 116);
        do Screen.drawLine(157, 116, 183, 120);
        do Screen.drawLine(183, 120, 176, 175);
        do Screen.drawLine(176, 175, 120, 167);
        // Colorado Border (inbetween these 2 lines)
        do Screen.drawLine(176, 173, 250, 182);
        do Screen.drawLine(182, 118, 248, 126);
        // Arizona + New Mexico Border (left = Arizona, right = New Mexico)
        do Screen.drawLine(177, 174, 171, 241);
        // Idaho Border (left of these lines is Idaho, right would be montana)
        do Screen.drawLine(158, 99, 164, 62);
        do Screen.drawLine(164, 62, 146, 62);
        do Screen.drawLine(146, 62, 131, 42);
        do Screen.drawLine(131, 42, 136, 7);
        // Montana + Wymoning Border (above is montana, below is colorado)
        do Screen.drawLine(164, 60, 256, 71);
        // Names of each state
        // Washington 
        do Output.moveCursor(3, 9);
        do Output.printString("WA (3)");
        // Oregon 
        do Output.moveCursor(7, 7);
        do Output.printString("OR (2)");
        // California 
        do Output.moveCursor(14, 7);
        do Output.printString("CA (1)");
        // Idaho 
        do Output.moveCursor(5, 15);
        do Output.printString("ID (@)");
        // Nevada
        do Output.moveCursor(12, 10);
        do Output.printString("NV (4)");
        // Utah (up and left)
        do Output.moveCursor(12, 17);
        do Output.printString("UT (5)");
        // Montana
        do Output.moveCursor(4, 24);
        do Output.printString("MT (6)");
        // Wyoming (move down)
        do Output.moveCursor(7, 24);
        do Output.printString("WY (7)");
        // Colorado
        do Output.moveCursor(14, 26);
        do Output.printString("CO (8)");
        // Arizona
        do Output.moveCursor(17, 17);
        do Output.printString("AZ (9)");
        // New Mexico
        do Output.moveCursor(18, 26);
        do Output.printString("NM (!)");

        return;
    }

