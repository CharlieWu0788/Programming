class Sprites {
    // pokes sprite into memory using logical OR in order to preserve the image below
    function void additivePoke(int addr, int newVal) {
        var int currVal;

        if ((addr < 16384) | (addr > 24576)) {
            return;
        }

        let currVal = Memory.peek(addr);
        do Memory.poke(addr, (currVal | newVal));
        return;
    }

    // pokes white sprite into memory by combining it with a negated version of the underlying image
    function void subtractivePoke(int addr, int blackVal) {
        var int currVal, whiteVal;

        if ((addr < 16384) | (addr > 24576)) {
            return;
        }

        let currVal = Memory.peek(addr);
        if (currVal = 0) { return; }

        let whiteVal = (currVal & ~(blackVal));
        do Memory.poke(addr, whiteVal);
        
        return;
    }

    function void drawZeke(int location) {
        do Sprites.drawInvertedZeke(location - 65);
        do Sprites.drawZekeLines(location);
        return;
    }

    function void drawInvertedZeke(int location) {
        var int memAddress; 
        let memAddress = 16384+location;
        // column 0
        do Sprites.subtractivePoke(memAddress +7296, 0);
