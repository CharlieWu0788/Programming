    function void drawHealthBar(int location, int hp) {
        var int i;

        //do Sprites.drawHealthBarNegativeSpace(location + 64);
        do Sprites.drawInvertedHealthBar(location - 64);
        do Sprites.drawHealthBarLines(location);

        let i = 0;
        while (i < hp) {
            do Sprites.drawHPUnit(location + 896 + 2 + (i * 2));
            let i = i + 1;
        }

        return;
    }

