    function void drawHPUnit(int location) {
        var int memAddress; 
        let memAddress = 16384+location;
        // column 0
        do Sprites.additivePoke(memAddress, -512);
        do Sprites.additivePoke(memAddress +32, 768);
        do Sprites.additivePoke(memAddress +64, -640);
        do Sprites.additivePoke(memAddress +96, -320);
        do Sprites.additivePoke(memAddress +128, -160);
        do Sprites.additivePoke(memAddress +160, -80);
        do Sprites.additivePoke(memAddress +192, -40);
        do Sprites.additivePoke(memAddress +224, 12);
        do Sprites.additivePoke(memAddress +256, -2);
        // column 1
        do Sprites.additivePoke(memAddress +1, -1);
        do Sprites.additivePoke(memAddress +33, -16384);
        do Sprites.additivePoke(memAddress +65, 28671);
        do Sprites.additivePoke(memAddress +97, 14335);
        do Sprites.additivePoke(memAddress +129, 7167);
        do Sprites.additivePoke(memAddress +161, 3583);
        do Sprites.additivePoke(memAddress +193, 1791);
        do Sprites.additivePoke(memAddress +225, 768);
        do Sprites.additivePoke(memAddress +257, 511);
        // column 2
        do Sprites.additivePoke(memAddress +2, 1);
        return;
    }

